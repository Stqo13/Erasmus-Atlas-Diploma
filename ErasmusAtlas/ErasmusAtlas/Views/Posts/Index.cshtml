@model ErasmusAtlas.ViewModels.PostViewModels.PostIndexViewModel

@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Posts";
}

@section Styles {
    <link rel="stylesheet" href="~/css/posts-index.css" asp-append-version="true" />
}

<div class="content-inner posts-page">
    <div class="posts-header card">
        <div class="card-body posts-header-body">
            <div>
                <h2 class="h1">Explore posts</h2>
                <div class="muted">Browse Erasmus experiences, tips, and student insights.</div>
            </div>

            <div class="posts-header-actions">
                <a asp-controller="Posts" asp-action="Mine" class="btn">My Posts</a>
                <a asp-controller="Posts" asp-action="Create" class="btn btn-primary">Create Post</a>
            </div>
        </div>
    </div>

    <div class="posts-grid">
        @if (Model.Posts == null || !Model.Posts.Any())
        {
            <div class="card">
                <div class="card-body">
                    <h3 class="empty-title">No posts found</h3>
                    <div class="muted">Try changing your filters or create the first post.</div>
                </div>
            </div>
        }
        else
        {
            @foreach (var post in Model.Posts)
            {
                <article class="card post-card">
                    <div class="card-body">
                        <div class="post-meta-top">
                            <span class="post-city">@post.City</span>
                            <span class="post-date">@post.CreatedOn.ToString("dd MMM yyyy")</span>
                        </div>

                        <h3 class="post-title">
                            <a asp-controller="Posts" asp-action="Details" asp-route-id="@post.Id">
                                @post.Title
                            </a>
                        </h3>

                        <div class="post-topics">
                            @foreach (var topic in post.Topics)
                            {
                                <span class="topic-pill">@topic</span>
                            }
                        </div>

                        <div class="post-actions">
                            <a asp-controller="Posts" asp-action="Details" asp-route-id="@post.Id" class="btn btn-primary">
                                View Details
                            </a>
                        </div>
                    </div>
                </article>
            }
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="pagination-wrap">
            @if (Model.HasPreviousPage)
            {
                <a class="pagination-link"
                   asp-controller="Posts"
                   asp-action="Index"
                   asp-route-city="@Model.City"
                   asp-route-topic="@Model.Topic"
                   asp-route-page="@(Model.CurrentPage - 1)"
                   asp-route-pageSize="@Model.PageSize">
                    Previous
                </a>
            }

            @{
                var currentPage = Model.CurrentPage;
                var totalPages = Model.TotalPages;

                var pages = new List<int>();

                pages.Add(1);

                if (currentPage <= 2)
                {
                    if (totalPages >= 2)
                    {
                        pages.Add(2);
                    }

                    if (totalPages >= 3 && currentPage == 2)
                    {
                        pages.Add(3);
                    }
                }
                else if (currentPage >= totalPages - 1)
                {
                    if (totalPages - 2 > 1)
                    {
                        pages.Add(totalPages - 2);
                    }

                    if (totalPages - 1 > 1)
                    {
                        pages.Add(totalPages - 1);
                    }
                }
                else
                {
                    if (currentPage - 1 > 1)
                    {
                        pages.Add(currentPage - 1);
                    }

                    if (currentPage > 1 && currentPage < totalPages)
                    {
                        pages.Add(currentPage);
                    }

                    if (currentPage + 1 < totalPages)
                    {
                        pages.Add(currentPage + 1);
                    }
                }

                if (totalPages > 1)
                {
                    pages.Add(totalPages);
                }

                pages = pages
                .Where(p => p >= 1 && p <= totalPages)
                .Distinct()
                .OrderBy(p => p)
                .ToList();

                int? previousPageNumber = null;
            }

            @foreach (var pageNumber in pages)
            {
                if (previousPageNumber.HasValue && pageNumber - previousPageNumber.Value > 1)
                {
                    <span class="pagination-dots">...</span>
                }

                <a class="pagination-link @(pageNumber == Model.CurrentPage ? "active" : "")"
                   asp-controller="Posts"
                   asp-action="Index"
                   asp-route-city="@Model.City"
                   asp-route-topic="@Model.Topic"
                   asp-route-page="@pageNumber"
                   asp-route-pageSize="@Model.PageSize">
                    @pageNumber
                </a>

                previousPageNumber = pageNumber;
            }

            @if (Model.HasNextPage)
            {
                <a class="pagination-link"
                   asp-controller="Posts"
                   asp-action="Index"
                   asp-route-city="@Model.City"
                   asp-route-topic="@Model.Topic"
                   asp-route-page="@(Model.CurrentPage + 1)"
                   asp-route-pageSize="@Model.PageSize">
                    Next
                </a>
            }
        </div>
    }
</div>
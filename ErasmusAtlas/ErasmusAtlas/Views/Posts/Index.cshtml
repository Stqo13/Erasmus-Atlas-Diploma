@model IEnumerable<ErasmusAtlas.ViewModels.PostViewModels.PostInfoViewModel>

@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Posts";
}

@section Styles {
    <link rel="stylesheet" href="~/css/posts-index.css" asp-append-version="true" />
}

<div class="content-inner posts-page">
    <div class="posts-header card">
        <div class="card-body posts-header-body">
            <div>
                <h2 class="h1">Explore posts</h2>
                <div class="muted">Browse Erasmus experiences, tips, and student insights.</div>
            </div>

            <div class="posts-header-actions">
                <a asp-controller="Posts" asp-action="Mine" class="btn">My Posts</a>
                <a asp-controller="Posts" asp-action="Create" class="btn btn-primary">Create Post</a>
            </div>
        </div>
    </div>

    <div class="posts-grid">
        @if (Model == null || !Model.Any())
        {
            <div class="card">
                <div class="card-body">
                    <h3 class="empty-title">No posts found</h3>
                    <div class="muted">Try changing your filters or create the first post.</div>
                </div>
            </div>
        }
        else
        {
            @foreach (var post in Model)
            {
                <article class="card post-card">
                    <div class="card-body">
                        <div class="post-meta-top">
                            <span class="post-city">@post.City</span>
                            <span class="post-date">@post.CreatedOn.ToString("dd MMM yyyy")</span>
                        </div>

                        <h3 class="post-title">
                            <a asp-controller="Posts" asp-action="Details" asp-route-id="@post.Id">
                                @post.Title
                            </a>
                        </h3>

                        <div class="post-topics">
                            @foreach (var topic in post.Topics)
                            {
                                <span class="topic-pill">@topic</span>
                            }
                        </div>

                        <div class="post-actions">
                            <a asp-controller="Posts" asp-action="Details" asp-route-id="@post.Id" class="btn btn-primary">
                                View Details
                            </a>
                        </div>
                    </div>
                </article>
            }
        }
    </div>
</div>
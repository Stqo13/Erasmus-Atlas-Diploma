@model ErasmusAtlas.ViewModels.AccountViewModels.RegisterViewModel;

@{
    Layout = "_LayoutPublic";
    ViewData["Title"] = "Register";
    var returnUrl = ViewBag.ReturnUrl as string;
}

<div class="card">
    <div class="card-header">
        <h1 class="h1">Create your account</h1>
        <p class="muted">Choose a unique username and complete your profile details.</p>
    </div>

    <div class="card-body">
        <form class="form" asp-controller="Account" asp-action="Register" method="post">
            @Html.AntiForgeryToken()

            @if (!string.IsNullOrWhiteSpace(returnUrl))
            {
                <input type="hidden" name="returnUrl" value="@returnUrl" />
            }

            <div asp-validation-summary="ModelOnly" class="validation"></div>

            <div class="row">
                <div class="field">
                    <label asp-for="FirstName"></label>
                    <input class="input" asp-for="FirstName" autocomplete="given-name" />
                    <span asp-validation-for="FirstName" class="validation"></span>
                </div>

                <div class="field">
                    <label asp-for="LastName"></label>
                    <input class="input" asp-for="LastName" autocomplete="family-name" />
                    <span asp-validation-for="LastName" class="validation"></span>
                </div>
            </div>

            <div class="field">
                <label asp-for="Username"></label>
                <input class="input" asp-for="Username" autocomplete="username" />
                <span asp-validation-for="Username" class="validation"></span>
                <div class="muted" style="font-size:13px; margin-top:6px;">
                    Allowed: letters, numbers, dot, underscore, dash.
                </div>
            </div>

            <div class="field">
                <label asp-for="Email"></label>
                <input class="input" asp-for="Email" autocomplete="email" />
                <span asp-validation-for="Email" class="validation"></span>
            </div>

            <div class="row">
                <div class="field">
                    <label asp-for="Password"></label>
                    <input class="input" asp-for="Password" autocomplete="new-password" />
                    <span asp-validation-for="Password" class="validation"></span>
                </div>

                <div class="field">
                    <label asp-for="ConfirmPassword"></label>
                    <input class="input" asp-for="ConfirmPassword" autocomplete="new-password" />
                    <span asp-validation-for="ConfirmPassword" class="validation"></span>
                </div>
            </div>

            <div class="actions">
                <a class="btn" asp-controller="Home" asp-action="Index">Cancel</a>
                <button class="btn btn-primary" type="submit">Create account</button>
            </div>

            <div class="muted" style="margin-top:14px;">
                Already have an account?
                <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="@returnUrl">Login</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

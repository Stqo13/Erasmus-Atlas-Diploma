@model ErasmusAtlas.ViewModels.AdminViewModels.AdminProjectsPageViewModel

@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Manage Projects";
}

<div class="content-inner admin-page">
    <div class="card">
        <div class="card-body">
            <h2 class="h1">Manage Projects</h2>
            <div class="muted">Review and delete projects as an administrator.</div>
        </div>
    </div>

    <div class="admin-users-list">
        @foreach (var project in Model.Projects)
        {
            <article class="card admin-user-card">
                <div class="card-body admin-user-card-body">
                    <div>
                        <h3 class="admin-user-name">@project.Title</h3>
                        <div class="muted">@project.City • @project.ProjectType • @project.CreatedOn.ToString("dd MMM yyyy")</div>
                    </div>

                    <div class="admin-user-actions">
                        <a asp-controller="Projects" asp-action="Details" asp-route-id="@project.Id" class="btn btn-primary">View</a>

                        <form asp-controller="Admin" asp-action="DeleteProject" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@project.Id" />
                            <button type="submit" class="btn">Delete</button>
                        </form>
                    </div>
                </div>
            </article>
        }
    </div>
</div>
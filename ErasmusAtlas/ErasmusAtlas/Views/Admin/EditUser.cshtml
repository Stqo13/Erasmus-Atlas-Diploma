@model ErasmusAtlas.ViewModels.AdminViewModels.AdminEditUserViewModel

@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Edit User";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-edit-user.css" asp-append-version="true" />
}

<div class="content-inner admin-page">
    <div class="card">
        <div class="card-body">
            <h2 class="h1">Edit User</h2>
            <div class="muted">Update user data and manage roles.</div>

            <form asp-controller="Admin" asp-action="EditUser" method="post" class="form">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div class="row">
                    <div class="field">
                        <label asp-for="Email"></label>
                        <input asp-for="Email" class="input" />
                    </div>

                    <div class="field">
                        <label asp-for="UserName"></label>
                        <input asp-for="UserName" class="input" />
                    </div>
                </div>

                <div class="row">
                    <div class="field">
                        <label asp-for="FirstName"></label>
                        <input asp-for="FirstName" class="input" />
                    </div>

                    <div class="field">
                        <label asp-for="LastName"></label>
                        <input asp-for="LastName" class="input" />
                    </div>
                </div>

                <div class="field">
                    <label asp-for="DisplayName"></label>
                    <input asp-for="DisplayName" class="input" />
                </div>

                <div class="field">
                    <label asp-for="Bio"></label>
                    <textarea asp-for="Bio" class="input" rows="5"></textarea>
                </div>

                <div class="field">
                    <label>Roles</label>
                    <div class="admin-role-selector">
                        @foreach (var role in Model.AllRoles)
                        {
                            var isChecked = Model.SelectedRoles.Contains(role);

                            <label class="role-check">
                                <input type="checkbox" name="SelectedRoles" value="@role" @(isChecked ? "checked" : null) />
                                <span>@role</span>
                            </label>
                        }
                    </div>
                </div>

                <div class="actions">
                    <a asp-controller="Admin" asp-action="Users" class="btn">Cancel</a>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>
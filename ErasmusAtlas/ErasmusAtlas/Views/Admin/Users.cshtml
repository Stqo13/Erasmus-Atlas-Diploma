@model ErasmusAtlas.ViewModels.AdminViewModels.AdminUsersPageViewModel

@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Manage Users";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-users.css" asp-append-version="true" />
}

<div class="content-inner admin-page">
    <div class="card">
        <div class="card-body">
            <h2 class="h1">Manage Users</h2>
            <div class="muted">Grant roles, remove roles, edit data, and delete users.</div>
        </div>
    </div>

    <div class="admin-users-list">
        @foreach (var user in Model.Users)
        {
            <article class="card admin-user-card">
                <div class="card-body admin-user-card-body">
                    <div>
                        <h3 class="admin-user-name">@user.DisplayName</h3>
                        <div class="muted">@user.UserName • @user.Email</div>
                        <div class="admin-user-meta">@user.FirstName @user.LastName</div>

                        <div class="admin-role-list">
                            @foreach (var role in user.Roles)
                            {
                                <span class="role-pill">@role</span>
                            }
                        </div>
                    </div>

                    <div class="admin-user-actions">
                        <a asp-controller="Admin" asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-primary">Edit</a>

                        <form asp-controller="Admin" asp-action="DeleteUser" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@user.Id" />
                            <button type="submit" class="btn">Delete</button>
                        </form>
                    </div>
                </div>
            </article>
        }
    </div>
</div>
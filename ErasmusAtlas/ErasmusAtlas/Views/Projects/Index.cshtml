@model ErasmusAtlas.ViewModels.ProjectViewModels.ProjectsIndexPageViewModel

@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Projects";
}

@section Styles {
    <link rel="stylesheet" href="~/css/projects-index.css" asp-append-version="true" />
}

<div class="content-inner projects-page">
    <div class="card">
        <div class="card-body">
            <div class="projects-header">
                <div>
                    <h2 class="h1">Explore projects</h2>
                    <div class="muted">Browse Erasmus opportunities by city, type, and tags.</div>
                </div>
            </div>

            <form asp-controller="Projects" asp-action="Index" method="get" class="form project-filters">
                <input type="hidden" name="Page" value="1" />
                <input type="hidden" name="PageSize" value="@Model.PageSize" />

                <div class="row">
                    <div class="field">
                        <label for="SearchTerm">Search</label>
                        <input id="SearchTerm"
                               name="SearchTerm"
                               class="input"
                               placeholder="Search by title or description"
                               value="@Model.Filter.SearchTerm" />
                    </div>

                    <div class="field">
                        <label for="CityId">City</label>
                        <select id="CityId" name="CityId" class="input">
                            <option value="">All cities</option>
                            @foreach (var city in Model.Cities)
                            {
                                <option value="@city.Id" selected="@(Model.Filter.CityId == city.Id)">
                                    @city.Name
                                </option>
                            }
                        </select>
                    </div>
                </div>

                <div class="row">
                    <div class="field">
                        <label for="ProjectTypeId">Project Type</label>
                        <select id="ProjectTypeId" name="ProjectTypeId" class="input">
                            <option value="">All project types</option>
                            @foreach (var type in Model.ProjectTypes)
                            {
                                <option value="@type.Id" selected="@(Model.Filter.ProjectTypeId == type.Id)">
                                    @type.Name
                                </option>
                            }
                        </select>
                    </div>

                    <div class="field">
                        <label>Tags</label>
                        <div class="tags-selector">
                            @foreach (var tag in Model.Tags)
                            {
                                var isChecked = Model.Filter.TagIds.Contains(tag.Id);

                                <label class="tag-check">
                                    <input type="checkbox" name="TagIds" value="@tag.Id" @(isChecked ? "checked" : null) />
                                    <span>@tag.Name</span>
                                </label>
                            }
                        </div>
                    </div>
                </div>

                <div class="actions">
                    <a asp-controller="Projects" asp-action="Index" class="btn">Clear</a>
                    <button type="submit" class="btn btn-primary">Apply Filters</button>
                </div>
            </form>
        </div>
    </div>

    <div class="projects-grid">
        @if (Model.Projects == null || !Model.Projects.Any())
        {
            <div class="card">
                <div class="card-body">
                    <h3 class="empty-title">No projects found</h3>
                    <div class="muted">Try changing the filters to see more opportunities.</div>
                </div>
            </div>
        }
        else
        {
            @foreach (var project in Model.Projects)
            {
                <article class="card project-card">
                    <div class="card-body">
                        <div class="project-meta-top">
                            <span class="project-city">@project.City</span>
                            <span class="project-date">@project.CreatedOn.ToString("dd MMM yyyy")</span>
                        </div>

                        <h3 class="project-title">
                            <a asp-controller="Projects" asp-action="Details" asp-route-id="@project.Id">
                                @project.Title
                            </a>
                        </h3>

                        <div class="project-type">@project.ProjectType</div>
                        <div class="project-institution">@project.Institution</div>

                        <p class="project-description">
                            @project.DescriptionPreview
                        </p>

                        <div class="project-tags">
                            @foreach (var tag in project.Tags)
                            {
                                <span class="tag-pill">@tag</span>
                            }
                        </div>

                        <div class="project-actions">
                            <a asp-controller="Projects" asp-action="Details" asp-route-id="@project.Id" class="btn btn-primary">
                                View Details
                            </a>
                        </div>
                    </div>
                </article>
            }
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        string BuildPageUrl(int targetPage)
        {
            var queryParts = new List<string>();

            if (!string.IsNullOrWhiteSpace(Model.Filter.SearchTerm))
            {
                queryParts.Add($"SearchTerm={Uri.EscapeDataString(Model.Filter.SearchTerm)}");
            }

            if (Model.Filter.CityId.HasValue)
            {
                queryParts.Add($"CityId={Model.Filter.CityId.Value}");
            }

            if (Model.Filter.ProjectTypeId.HasValue)
            {
                queryParts.Add($"ProjectTypeId={Model.Filter.ProjectTypeId.Value}");
            }

            if (Model.Filter.TagIds != null && Model.Filter.TagIds.Any())
            {
                foreach (var tagId in Model.Filter.TagIds)
                {
                    queryParts.Add($"TagIds={tagId}");
                }
            }

            queryParts.Add($"Page={targetPage}");
            queryParts.Add($"PageSize={Model.PageSize}");

            return Url.Action("Index", "Projects") + "?" + string.Join("&", queryParts);
        }

        var currentPage = Model.CurrentPage;
        var totalPages = Model.TotalPages;
        var pages = new List<int> { 1 };

        if (currentPage <= 2)
        {
            if (totalPages >= 2)
            {
                pages.Add(2);
            }

            if (totalPages >= 3 && currentPage == 2)
            {
                pages.Add(3);
            }
        }
        else if (currentPage >= totalPages - 1)
        {
            if (totalPages - 2 > 1)
            {
                pages.Add(totalPages - 2);
            }

            if (totalPages - 1 > 1)
            {
                pages.Add(totalPages - 1);
            }
        }
        else
        {
            if (currentPage - 1 > 1)
            {
                pages.Add(currentPage - 1);
            }

            if (currentPage > 1 && currentPage < totalPages)
            {
                pages.Add(currentPage);
            }

            if (currentPage + 1 < totalPages)
            {
                pages.Add(currentPage + 1);
            }
        }

        if (totalPages > 1)
        {
            pages.Add(totalPages);
        }

        pages = pages
        .Where(p => p >= 1 && p <= totalPages)
        .Distinct()
        .OrderBy(p => p)
        .ToList();

        int? previousPageNumber = null;

        <div class="pagination-wrap">
            @if (Model.HasPreviousPage)
            {
                <a class="pagination-link" href="@BuildPageUrl(Model.CurrentPage - 1)">
                    Previous
                </a>
            }

            @foreach (var pageNumber in pages)
            {
                if (previousPageNumber.HasValue && pageNumber - previousPageNumber.Value > 1)
                {
                    <span class="pagination-dots">...</span>
                }

                <a class="pagination-link @(pageNumber == Model.CurrentPage ? "active" : "")"
                   href="@BuildPageUrl(pageNumber)">
                    @pageNumber
                </a>

                previousPageNumber = pageNumber;
            }

            @if (Model.HasNextPage)
            {
                <a class="pagination-link" href="@BuildPageUrl(Model.CurrentPage + 1)">
                    Next
                </a>
            }
        </div>
    }
</div>
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ErasmusUser> SignInManager

@{
    string currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    string Active(string name) => currentController.Equals(name, StringComparison.OrdinalIgnoreCase) ? "active" : "";
}

<div class="sidebar-brand">
    <a asp-controller="Home" asp-action="Index" class="brand-link">ErasmusAtlas</a>
    <span class="brand-badge" title="Erasmus+"></span>
</div>

<nav class="sidebar-nav">
    <a class="nav-item @Active("Posts")" asp-controller="Posts" asp-action="Index">Posts</a>
    <a class="nav-item @Active("Projects")" asp-controller="Projects" asp-action="Index">Projects</a>
    <a class="nav-item @Active("Map")" asp-controller="Map" asp-action="Index">Map</a>
    <a class="nav-item @Active("Home")" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
</nav>

<div class="sidebar-spacer"></div>

<div class="sidebar-footer">
    @if (SignInManager.IsSignedIn(User))
    {
        <form asp-controller="Account" asp-action="Logout" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="sidebar-signout">Sign out</button>
        </form>
    }
</div>
